<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/title_calculator"
        android:textColor="#212121"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editHourlyPay"
        android:layout_width="355dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@android:drawable/editbox_background_normal"
        android:hint="@string/hint_hourly_pay"
        android:inputType="numberDecimal"
        android:padding="14dp" />

    <EditText
        android:id="@+id/editAmountTime"
        android:layout_width="355dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@android:drawable/editbox_background_normal"
        android:hint="@string/hint_amount_time"
        android:inputType="numberDecimal"
        android:padding="14dp" />

    <EditText
        android:id="@+id/editBudget"
        android:layout_width="355dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@android:drawable/editbox_background_normal"
        android:hint="@string/hint_budget"
        android:inputType="numberDecimal"
        android:padding="14dp" />

    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_calculate"
        android:textSize="16sp"
        android:backgroundTint="#3F51B5"
        android:textColor="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="40dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_view_projects"
        android:textSize="16sp"
        android:backgroundTint="#2E7D32"
        android:textColor="#FFFFFF"
        android:padding="12dp"/>

</LinearLayout>